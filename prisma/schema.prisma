// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url      = env("DATABASE_URL")
}

enum SignalPrivacy {
    PUBLIC
    UNLISTED
    PRIVATE
}

model Signal {
    id        String        @id @default(nanoid())
    title     String
    prompt    String
    data      Json?
    sourceUrl String?       @unique @map("source_url")
    privacy   SignalPrivacy @default(PUBLIC)

    createdAt DateTime    @default(now())
    updatedAt DateTime    @updatedAt
    user      User?       @relation(fields: [userId], references: [id])
    userId    String?
    followUps FollowUps[]

    @@map("signals")
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String      @id @default(cuid())
    name          String?
    email         String?     @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
    signals         Signal[]
    followUps       FollowUps[]
    feedPreferences FeedPreferences?
    feedItems       FeedItem[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model FeedPreferences {
    id                 String   @id @default(nanoid())
    topics             String[]
    xAccounts          String[] @map("x_accounts")
    communicationStyle String   @default("balanced") @map("communication_style")
    affectiveLevel     Int      @default(30) @map("affective_level")
    language           String   @default("en")
    additionalInstructions String?  @map("additional_instructions")
    generatingBatchId      String?  @map("generating_batch_id")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String   @unique

    @@map("feed_preferences")
}

model FeedItem {
    id              String  @id @default(nanoid())
    headline        String
    content         String
    expandedContent String  @map("expanded_content")
    source          String
    sourceUrl       String  @map("source_url")
    sourceType      String  @default("article") @map("source_type")
    imageUrl        String?  @map("image_url")
    contentDate     String?  @map("content_date")
    topic           String
    batchId         String  @map("batch_id")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String

    @@index([userId, createdAt])
    @@map("feed_items")
}

model FollowUps {
    id        Int      @id @default(autoincrement())
    title     String?
    messages  Json     @default("[]")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    signal    Signal?  @relation(fields: [signalId], references: [id], onDelete: Cascade)
    signalId  String?
    user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String?
}
